# server 환경변수 예시 · 실값은 로컬 .env(gitignore) 또는 배포 플랫폼(Render) env에 넣는다.
# 값은 전부 자리표시 — 실제 시크릿을 여기에 커밋하지 말 것.

# DB (Neon Postgres)
DATABASE_URL=postgres://user:password@host/dbname
PGSSLMODE=require

# 세션 서명 · 실배포는 긴 랜덤 문자열
SESSION_SECRET=change-me-long-random
NODE_ENV=development
PORT=3001

# CORS/OAuth origin (배포)
CLIENT_ORIGIN=https://your-client.vercel.app
SERVER_ORIGIN=https://your-server.onrender.com

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# 관리자 판별(비우면 lib/admin.js 폴백) · 대시보드 통계 제외 계정
ADMIN_EMAILS=admin1@example.com,admin2@example.com
ADMIN_USERNAMES=minwoo
EXCLUDED_EMAILS=

# [V11] User Management 2차 게이트 PIN · 하드코딩 금지 · 실값은 Render env 에만 넣는다.
ADMIN_2FA_PIN=your-6-digit-2fa-pin

# 프로필 사진 저장(Vercel Blob) · 스토어는 public access 여야 아바타가 <img>로 표시됨
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# 데모/무마찰 토글(운영 전환 시)
DEMO_MODE=false
REQUIRE_DROPOFF=false
REQUIRE_PAYMETHOD=false

# 외부 교통 API
TAGO_SERVICE_KEY=your-tago-key
KAKAO_REST_KEY=your-kakao-key
